<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA">

    <!-- Toolbar Style Background -->
    <View
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#673AB7"/>

    <!-- Header Section -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:padding="16dp">

        <ImageButton
            android:id="@+id/btnAtras"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Cerrar"
            app:tint="#444444"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Calendario"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#222222"/>
    </RelativeLayout>

    <!-- Month Selector -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="16dp"
        android:background="#FFFFFF">

        <ImageButton
            android:id="@+id/btnMesAnterior"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#CCCCCC"/>

        <TextView
            android:id="@+id/tvMesAnio"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:text="marzo 2026"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:gravity="center"/>

        <ImageButton
            android:id="@+id/btnMesSiguiente"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_next"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#CCCCCC"/>
    </LinearLayout>

    <!-- Week Days Header -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="7"
        android:background="#FFFFFF"
        android:paddingVertical="8dp">

        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="Dom" android:gravity="center" android:textColor="#444444" android:textStyle="bold" android:textSize="14sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="Lun" android:gravity="center" android:textColor="#444444" android:textStyle="bold" android:textSize="14sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="Mar" android:gravity="center" android:textColor="#444444" android:textStyle="bold" android:textSize="14sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="Mié" android:gravity="center" android:textColor="#444444" android:textStyle="bold" android:textSize="14sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="Jue" android:gravity="center" android:textColor="#444444" android:textStyle="bold" android:textSize="14sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="Vie" android:gravity="center" android:textColor="#444444" android:textStyle="bold" android:textSize="14sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="Sáb" android:gravity="center" android:textColor="#444444" android:textStyle="bold" android:textSize="14sp"/>
    </GridLayout>

    <!-- Calendar Grid -->
    <GridLayout
        android:id="@+id/gridCalendario"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="7"
        android:background="#FFFFFF"
        android:paddingBottom="16dp"/>

    <!-- Content Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#F5F5F5">

        <TextView
            android:id="@+id/tvContadorRegistros"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2 registros"
            android:textColor="#888888"
            android:textSize="14sp"
            android:layout_marginBottom="12dp"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:id="@+id/layoutRegistros"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>
        </ScrollView>
    </LinearLayout>

</LinearLayout>
