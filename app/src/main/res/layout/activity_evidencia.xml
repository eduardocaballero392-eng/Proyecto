<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Top Toolbar Background (Purple) -->

    <View
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#673AB7" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Título con navegación -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Evidencia fotográfica"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#222222"/>
            </LinearLayout>

            <!-- Subtítulo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Toma fotos de los residuos para análisis con IA"
                android:textSize="14sp"
                android:textColor="#888888"
                android:layout_marginBottom="24dp"/>

            <!-- Card para Foto -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="30dp">

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@android:drawable/ic_menu_camera"
                        app:tint="#90CAF9"
                        android:layout_marginBottom="16dp"/>

                    <Button
                        android:id="@+id/btnFoto"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:text="Tomar Foto de Evidencia"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#2196F3"
                        app:cornerRadius="27dp"
                        android:layout_marginHorizontal="20dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="La IA analizará la imagen automáticamente"
                        android:textSize="12sp"
                        android:textColor="#AAAAAA"
                        android:layout_marginTop="12dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card Análisis IA -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔐 Análisis de IA"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Descripción de residuos:"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#444444"
                        android:layout_marginBottom="8dp"/>

                    <EditText
                        android:id="@+id/etDescripcion"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:hint="La descripción aparecerá aquí después de tomar la foto..."
                        android:gravity="top|start"
                        android:padding="16dp"
                        android:textSize="14sp"
                        android:background="@drawable/edittext_border"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sugerencia de reciclaje:"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#444444"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="El sistema identificará automáticamente el tipo de residuo y su contenedor correspondiente."
                        android:textSize="14sp"
                        android:textColor="#666666"
                        android:lineSpacingExtra="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card Detalles del registro -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Detalles del registro"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Peso estimado (kg):"
                        android:textSize="14sp"
                        android:textColor="#666666"
                        android:layout_marginBottom="8dp"/>

                    <EditText
                        android:id="@+id/etPesoEstimado"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:hint="0.0"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="16dp"
                        android:textSize="16sp"
                        android:background="@drawable/edittext_border"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Botón Guardar -->
            <Button
                android:id="@+id/btnGuardarRegistro"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Confirmar y Guardar"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF5722"
                app:cornerRadius="30dp"
                android:layout_marginBottom="20dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
