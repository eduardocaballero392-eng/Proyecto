<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E8F5E9">

    <!-- Header Toolbar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#2E7D32"
        android:paddingHorizontal="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_share"
                app:tint="#FFFFFF"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Registrar Recolección"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <TextView
            android:id="@+id/btnVolver"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="← VOLVER"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"/>
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Tipo de Residuo -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tipo de Residuo *"
                        android:textColor="#2E7D32"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp"/>

                    <Spinner
                        android:id="@+id/spinnerTipoResiduo"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/edittext_border"
                        android:paddingHorizontal="12dp"
                        android:layout_marginBottom="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp"
                        android:weightSum="2">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.2"
                            android:orientation="vertical"
                            android:paddingEnd="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cantidad *"
                                android:textColor="#2E7D32"
                                android:textStyle="bold"
                                android:textSize="14sp"
                                android:layout_marginBottom="8dp"/>

                            <EditText
                                android:id="@+id/etPesoEstimado"
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:background="@drawable/edittext_border"
                                android:hint="0,00"
                                android:inputType="numberDecimal"
                                android:paddingHorizontal="16dp"
                                android:textColor="#000000"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.8"
                            android:orientation="vertical"
                            android:paddingStart="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Unidad *"
                                android:textColor="#2E7D32"
                                android:textStyle="bold"
                                android:textSize="14sp"
                                android:layout_marginBottom="8dp"/>

                            <EditText
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:background="@drawable/edittext_border"
                                android:text="kg"
                                android:enabled="false"
                                android:paddingHorizontal="16dp"
                                android:textColor="#000000"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Fecha y Hora -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fecha y Hora *"
                        android:textColor="#2E7D32"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvFechaHora"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/edittext_border"
                        android:padding="16dp"
                        android:text="09/03/2025 16:32"
                        android:textColor="#000000"
                        android:layout_marginBottom="16dp"
                        android:gravity="center_vertical"/>

                    <!-- Sucursal -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sucursal"
                        android:textColor="#2E7D32"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp"/>

                    <EditText
                        android:id="@+id/etSucursal"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/edittext_border"
                        android:hint="Sucursal San Isidro"
                        android:paddingHorizontal="16dp"
                        android:textColor="#000000"
                        android:layout_marginBottom="16dp"/>

                    <!-- Comentarios (opcional) -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Comentarios (opcional)"
                        android:textColor="#2E7D32"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp"/>

                    <EditText
                        android:id="@+id/etComentarios"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:background="@drawable/edittext_border"
                        android:hint="Escribe observaciones aquí..."
                        android:gravity="top"
                        android:padding="12dp"
                        android:textColor="#000000"
                        android:layout_marginBottom="24dp"/>

                    <!-- Botón Registrar -->
                    <Button
                        android:id="@+id/btnGuardarRegistro"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:backgroundTint="#2E7D32"
                        android:text="REGISTRAR"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        app:cornerRadius="4dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
