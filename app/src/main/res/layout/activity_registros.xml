<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Header con título y botón atrás -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnAtras"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="@android:color/transparent"
            android:contentDescription="Regresar"
            android:scaleType="centerInside"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📋 Historial de recolecciones"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:gravity="center"/>
    </LinearLayout>

    <!-- FILTROS: Categoría y Mes (AGREGADOS) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#FFFFFF"
        android:layout_marginBottom="8dp"
        android:weightSum="2">

        <!-- Spinner de Categorías -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingEnd="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" Categoría:"
                android:textSize="12sp"
                android:textColor="#666666"/>

            <Spinner
                android:id="@+id/spinnerCategoria"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/spinner_border"
                android:padding="8dp"/>
        </LinearLayout>

        <!-- Spinner de Mes -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" Mes:"
                android:textSize="12sp"
                android:textColor="#666666"/>

            <Spinner
                android:id="@+id/spinnerMes"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/spinner_border"
                android:padding="8dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Selector de filtros rápido (opcional, puedes mantenerlo o quitarlo) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:layout_marginBottom="8dp"
        android:visibility="gone"> <!-- Lo ocultamos para no duplicar -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔍 Filtrar por:"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#666666"
            android:layout_marginBottom="8dp"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="4dp">

                <Button
                    android:id="@+id/btnTodo"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Todos"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#2E7D32"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnPapel"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="📦 Papel"
                    android:textSize="12sp"
                    android:textColor="#666666"
                    android:backgroundTint="#E0E0E0"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnPlastico"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="🥤 Plástico"
                    android:textSize="12sp"
                    android:textColor="#666666"
                    android:backgroundTint="#E0E0E0"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnVidrio"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="🍾 Vidrio"
                    android:textSize="12sp"
                    android:textColor="#666666"
                    android:backgroundTint="#E0E0E0"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnOrganico"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="🍌 Orgánico"
                    android:textSize="12sp"
                    android:textColor="#666666"
                    android:backgroundTint="#E0E0E0"/>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- Estadísticas rápidas -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:weightSum="3"
        android:layout_marginBottom="8dp">

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginEnd="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊"
                    android:textSize="20sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total"
                    android:textSize="11sp"
                    android:textColor="#666666"/>

                <TextView
                    android:id="@+id/tvTotalRegistros"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="24"
                    android:textColor="#1E201E"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginEnd="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚖️"
                    android:textSize="20sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Peso total"
                    android:textSize="11sp"
                    android:textColor="#666666"/>

                <TextView
                    android:id="@+id/tvPesoTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="156 kg"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#292A2B"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅"
                    android:textSize="20sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Este mes"
                    android:textSize="11sp"
                    android:textColor="#666666"/>

                <TextView
                    android:id="@+id/tvPesoMes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="42 kg"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#222120"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- Título de la lista -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="  Registros recientes"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp"/>

    <!-- Lista de registros -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="12dp"
        android:paddingBottom="16dp" />

</LinearLayout>